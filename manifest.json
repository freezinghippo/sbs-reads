{
  "name": "SB's Reads",
  "short_name": "SB's Reads",
  "description": "Your personal reading list. Save and revisit article links.",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "background_color": "#0d0d15",
  "theme_color": "#0d0d15",
  "orientation": "portrait",
  "icons": [
    { "src": "icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable" }
  ],
  "share_target": {
    "action": "./",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
}
